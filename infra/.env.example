# ============================================
# Copie este arquivo para .env e preencha
# NUNCA commite o .env no git
# ============================================

# --- Estabelecimento ---
ESTABELECIMENTO_NOME=Nome do Estabelecimento
ESTABELECIMENTO_TIPO=restaurante          # restaurante | barbearia | clinica | loja | outro
ESTABELECIMENTO_TEL=5511999999999
HORARIO_ABERTURA=18:00
HORARIO_FECHAMENTO=23:00
DIAS_FUNCIONAMENTO=ter,qua,qui,sex,sab,dom

# --- Geolocalização do estabelecimento ---
# Obter em: https://www.latlong.net ou Google Maps (clique direito → "O que há aqui?")
ESTABELECIMENTO_LAT=-23.550520
ESTABELECIMENTO_LNG=-46.633308

# --- Geocoding (converter endereço em lat/lng) ---
# Nominatim usa OpenStreetMap — gratuito, sem chave, limite 1 req/s
# Documentação: https://nominatim.org/release-docs/latest/api/Search/
GEOCODING_PROVIDER=nominatim

# --- Ambiente ---
APP_ENV=production                        # production | dev | qa

# --- Features (true/false) ---
FEATURE_DELIVERY=true
FEATURE_RETIRADA=true
FEATURE_RESERVAS=false                    # ativar para estabelecimentos com salão
FEATURE_PEDIDO_MESA=false                 # pedido pelo WhatsApp para consumo no local
FEATURE_STATUS_NOTIFICATIONS=true         # notificar cliente via WhatsApp ao mudar status do pedido

# --- Pedidos (se FEATURE_DELIVERY=true) ---
PEDIDO_MINIMO=0
TAXA_ENTREGA=0                            # taxa fixa de entrega (0 = grátis)
FRETE_GRATIS_ACIMA=0                      # pedidos acima deste valor têm frete grátis (0 = desativado)
TEMPO_PREPARO_MIN=25                      # minutos de preparo antes de sair para entrega
RAIO_MAXIMO_KM=15                         # limite de atendimento em km de linha reta

# --- Handoff para atendente humano ---
PEDIDO_HANDOFF_ACIMA=300                  # valor do carrinho que força handoff (0 = desativado)
MSG_HANDOFF_INICIO=Estou te conectando com um atendente. Aguarde um momento!
MSG_HANDOFF_RETORNO=Atendimento encerrado. Posso ajudar com mais alguma coisa?
MSG_HANDOFF_FILA=Todos os atendentes estão ocupados. Retornaremos em breve!

# --- WhatsApp Cloud API (Meta oficial) ---
# Obter em: https://developers.facebook.com/apps → WhatsApp → Configuração da API
WHATSAPP_ACCESS_TOKEN=EAAxxxxx          # Token permanente (gerar em Meta Business Suite → System Users)
WHATSAPP_PHONE_NUMBER_ID=              # ID do número (não o número em si) — aba "Primeiros passos"
WHATSAPP_BUSINESS_ACCOUNT_ID=         # WABA ID — exibido na conta da API
WHATSAPP_WEBHOOK_VERIFY_TOKEN=sakura_webhook_secret  # String livre — você define, usa na verificação do webhook
WHATSAPP_API_VERSION=v21.0            # Versão da Graph API

# --- Evolution API (DEPRECADO — substituído pela Meta Cloud API) ---
# AUTHENTICATION_API_KEY=sua_chave_aqui
# AUTHENTICATION_JWT_SECRET=seu_jwt_secret_aqui
# EVOLUTION_INSTANCE_NAME=nome-da-instancia
# EVOLUTION_INSTANCE_TOKEN=token-gerado-ao-criar-instancia

# --- n8n ---
N8N_EMAIL=admin@sakura.local          # e-mail do owner (criado no primeiro 'make init')
N8N_USER=admin
N8N_PASSWORD=senha_forte_aqui
N8N_HOST=n8n.seudominio.com.br

# --- Typebot ---
NEXTAUTH_SECRET=secret_aqui
ENCRYPTION_SECRET=encryption_secret_aqui
TYPEBOT_URL=https://bot.seudominio.com.br         # vazio = http://localhost:3001
TYPEBOT_VIEWER_URL=https://viewer.seudominio.com.br

# --- Chatwoot ---
SECRET_KEY_BASE=secret_aqui
CHATWOOT_URL=https://chat.seudominio.com.br        # vazio = http://localhost:3010
CHATWOOT_ADMIN_NAME=Admin
CHATWOOT_ADMIN_EMAIL=admin@sakura.local
CHATWOOT_ADMIN_PASSWORD=SakuraBot123

# --- n8n (webhook público — Meta Cloud API envia webhooks para esta URL) ---
# IMPORTANTE: deve ser HTTPS público. Use Railway/Fly.io ou ngrok para dev
N8N_WEBHOOK_URL=https://n8n.seudominio.com.br      # vazio = http://localhost:5678

# --- Banco de dados (PostgreSQL self-hosted) ---
POSTGRES_USER=botuser
POSTGRES_PASSWORD=senha_forte_aqui
POSTGRES_DB=botdb
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Groq (IA) ---
GROQ_API_KEY=gsk_xxxx

# --- Directus (Painel Admin) ---
DIRECTUS_SECRET=troque_por_uma_chave_aleatoria_longa
DIRECTUS_ADMIN_EMAIL=admin@sakura.com.br
DIRECTUS_ADMIN_PASSWORD=SenhaForte123!
DIRECTUS_URL=http://localhost:8055       # vazio = http://localhost:8055

# --- Keycloak (SSO - opcional) ---
DIRECTUS_AUTH_PROVIDERS=             # deixe vazio para desativar SSO
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_ISSUER_URL=                 # ex: http://keycloak:8080/realms/sakura

# --- Order Hub (painel operacional de pedidos) ---
# Gerar com: openssl rand -hex 32
ORDER_HUB_JWT_SECRET=troque_por_string_aleatoria_32_chars_minimo
ORDER_HUB_JWT_REFRESH_SECRET=troque_por_outra_string_aleatoria_diferente
# Segredo HMAC compartilhado com o n8n para assinar webhooks
ORDER_HUB_WEBHOOK_SECRET=troque_por_hmac_secret_compartilhado_com_n8n
