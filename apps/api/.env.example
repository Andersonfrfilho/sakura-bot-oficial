# Servidor
# Railway injeta PORT automaticamente — não setar no dashboard Railway
PORT=3333
NODE_ENV=development

# Banco de dados
# Local: hostname do serviço Docker Compose
# Railway: referência ao plugin PostgreSQL (${{Postgres.DATABASE_URL}})
DATABASE_URL=postgres://botuser:senha@postgres:5432/botdb

# Redis
# Local: hostname do serviço Docker Compose
# Railway: referência ao plugin Redis (${{Redis.REDIS_URL}})
REDIS_URL=redis://redis:6379

# Auth — gerar com: openssl rand -hex 32
JWT_SECRET=troque_para_string_aleatoria_de_32_chars_minimo
JWT_REFRESH_SECRET=troque_para_outra_string_aleatoria_diferente
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Webhook (compartilhado com o n8n)
WEBHOOK_SECRET=hmac_secret_compartilhado_com_n8n

# CORS — origens permitidas separadas por vírgula
ALLOWED_ORIGINS=http://localhost:4000,https://seu-web.up.railway.app

# Log
LOG_LEVEL=info
